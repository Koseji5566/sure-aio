#!/command/with-contenv sh
# WEB SERVICE
# Runs the main Rails application server

# Ensure we are in the app directory (usually /app or /rails in these images)
cd /rails

# Cleanup stale PIDs if container crashed
rm -f tmp/pids/server.pid

# Run the server
# We rely on existing ENV variables (PORT, SECRET_KEY_BASE, etc.) passed from Unraid
exec bin/rails server -b 0.0.0.0
