#!/command/with-contenv sh
cd /rails
export DB_HOST=127.0.0.1
export DB_PORT=5432
export POSTGRES_USER=sure_user
export POSTGRES_PASSWORD=internal_sure_pass
export POSTGRES_DB=sure_production
export REDIS_URL=redis://127.0.0.1:6379/1

# Wait strictly for pg to be responsive
echo "Waiting for PostgreSQL to become fully active..."
until pg_isready -h 127.0.0.1 -p 5432 -U sure_user; do
  sleep 2
done

echo "Running Sure database preparations (create/migrate/seed)..."
bundle exec rails db:prepare
