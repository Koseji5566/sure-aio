<?xml version="1.0"?>
<Container version="2">
  <Name>Sure-AIO</Name>
  <Repository>ghcr.io/jsonbored/sure-aio:latest</Repository>
  <Registry>https://github.com/we-promise/sure</Registry>
  <Network>bridge</Network>
  <WebUI>http://[IP]:[PORT:3000]</WebUI>
  <Privileged>false</Privileged>
  <Support>https://github.com/we-promise/sure/discussions</Support>
  <Project>https://github.com/we-promise/sure</Project>
  <Overview>
    Sure is a community-maintained personal finance app, forked from the archived Maybe Finance project. 
    This AIO (All-In-One) container runs both the web server and background workers.
  </Overview>
  <Category>Finance:Privacy</Category>
  <Icon>https://raw.githubusercontent.com/JSONbored/awesome-unraid/main/icons/sure.png</Icon>
  <Config Name="WebUI Port" Target="3000" Default="3000" Mode="tcp" Description="Sure WebUI port." Type="Port" Display="always" Required="true" Mask="false"/>
  <Config Name="App Domain" Target="APP_DOMAIN" Default="" Mode="" Description="The URL where Sure will be accessible. Example: http://192.168.1.100:3000" Type="Variable" Display="always" Required="true" Mask="false"/>
  <Config Name="Secret Key Base" Target="SECRET_KEY_BASE" Default="" Mode="" Description="Encryption key for sessions. Generate with: openssl rand -hex 64" Type="Variable" Display="always" Required="true" Mask="true"/>
  <Config Name="Database URL" Target="DATABASE_URL" Default="" Mode="" Description="(Recommended) PostgreSQL connection string. Format: postgresql://user:pass@postgres-shared:5432/sure" Type="Variable" Display="advanced" Required="false" Mask="true"/>
  <Config Name="Redis URL" Target="REDIS_URL" Default="" Mode="" Description="(Recommended) Redis connection string. Format: redis://redis-shared:6379/1" Type="Variable" Display="advanced" Required="false" Mask="true"/>
  <Config Name="App Storage" Target="/rails/storage" Default="/mnt/user/appdata/sure" Mode="rw" Description="Sure application data including SQLite database and attachments." Type="Path" Display="always" Required="true" Mask="false"/>
  <Config Name="Self Hosted" Target="SELF_HOSTED" Default="true" Mode="" Description="" Type="Variable" Display="advanced" Required="true" Mask="false"/>
  <Config Name="Rails Env" Target="RAILS_ENV" Default="production" Mode="" Description="" Type="Variable" Display="advanced" Required="true" Mask="false"/>
  <Config Name="Postgres DB" Target="POSTGRES_DB" Default="sure" Mode="" Description="Database name." Type="Variable" Display="advanced" Required="false" Mask="false"/>
  <Config Name="Postgres User" Target="POSTGRES_USER" Default="sure" Mode="" Description="Database username." Type="Variable" Display="advanced" Required="false" Mask="false"/>
  <Config Name="Postgres Password" Target="POSTGRES_PASSWORD" Default="" Mode="" Description="Database password." Type="Variable" Display="advanced" Required="false" Mask="true"/>
  <Config Name="Postgres Host" Target="POSTGRES_HOST" Default="postgres-shared" Mode="" Description="Database host." Type="Variable" Display="advanced" Required="false" Mask="false"/>
  <Config Name="Postgres Port" Target="POSTGRES_PORT" Default="5432" Mode="" Description="Database port." Type="Variable" Display="advanced" Required="false" Mask="false"/>
  <Config Name="OpenAI API Key" Target="OPENAI_API_KEY" Default="" Mode="" Description="OpenAI API key for AI features." Type="Variable" Display="advanced" Required="false" Mask="true"/>
  <Config Name="Anthropic API Key" Target="ANTHROPIC_API_KEY" Default="" Mode="" Description="Anthropic API key for AI features." Type="Variable" Display="advanced" Required="false" Mask="true"/>
  <Config Name="SMTP Address" Target="SMTP_ADDRESS" Default="" Mode="" Description="SMTP server address." Type="Variable" Display="advanced" Required="false" Mask="false"/>
  <Config Name="SMTP Port" Target="SMTP_PORT" Default="587" Mode="" Description="SMTP server port." Type="Variable" Display="advanced" Required="false" Mask="false"/>
  <Config Name="SMTP Username" Target="SMTP_USERNAME" Default="" Mode="" Description="SMTP username." Type="Variable" Display="advanced" Required="false" Mask="false"/>
  <Config Name="SMTP Password" Target="SMTP_PASSWORD" Default="" Mode="" Description="SMTP password." Type="Variable" Display="advanced" Required="false" Mask="true"/>
  <Config Name="Email Sender" Target="EMAIL_SENDER" Default="" Mode="" Description="Email address to send from." Type="Variable" Display="advanced" Required="false" Mask="false"/>
  <Config Name="Skip Migrations" Target="SKIP_MIGRATIONS" Default="false" Mode="" Description="Skip migrations if already initialized." Type="Variable" Display="advanced" Required="false" Mask="false"/>
  <Config Name="Onboarding State" Target="ONBOARDING_STATE" Default="open" Mode="" Description="open, closed, or invite_only" Type="Variable" Display="advanced" Required="false" Mask="false"/>
  <Config Name="Exchange Rate Provider" Target="EXCHANGE_RATE_PROVIDER" Default="yahoo_finance" Mode="" Description="twelve_data or yahoo_finance" Type="Variable" Display="advanced" Required="false" Mask="false"/>
  <Config Name="Securities Provider" Target="SECURITIES_PROVIDER" Default="yahoo_finance" Mode="" Description="twelve_data or yahoo_finance" Type="Variable" Display="advanced" Required="false" Mask="false"/>
  <Config Name="Twelve Data API Key" Target="TWELVE_DATA_API_KEY" Default="" Mode="" Description="" Type="Variable" Display="advanced" Required="false" Mask="true"/>
</Container>
